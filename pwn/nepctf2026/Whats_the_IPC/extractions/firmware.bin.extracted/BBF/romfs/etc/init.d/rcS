#! /bin/sh
hostname ni
mount -a
mkdir /dev/pts
mount -t devpts devpts /dev/pts
if [ ! -e "/dev/ptmx" ]; then
	mknod -m 666 /dev/ptmx c 5 24
fi
echo /sbin/mdev > /proc/sys/kernel/hotplug
mdev -s

mount -t squashfs /dev/mtdblock4 /opt/app
mount -t squashfs /dev/mtdblock5 /opt/web
mount -t squashfs /dev/mtdblock6 /opt/custom
mount -t jffs2 /dev/mtdblock7 /opt/sav -o sync

if [ -f /opt/sav/S99.sh ]; then
	sh /opt/sav/S99.sh
	exit 
fi

for initscript in /etc/init.d/S[0-9][0-9]*
do
    if [ -x $initscript ] ;
    then
        echo "[RCS]: $initscript"
        $initscript
    fi
done


